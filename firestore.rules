rules_version = '2';

// Northstar sync model: local SQLite is the source of truth; every record is
// mirrored to Firestore under users/{uid}/… (see data/SyncRepository.kt).
// A rider may only ever touch their own subtree — no cross-user reads/writes,
// and nothing is readable while signed out.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
